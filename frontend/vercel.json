{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "env": {
  "REACT_APP_API_URL": "https://medirush-backend.onrender.com/api",
  "REACT_APP_SOCKET_URL": "https://medirush-backend.onrender.com"
}
}
